# Copy this file to .env and fill in real values. .env is gitignored.

# Hugging Face Hub (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here
HF_USERNAME=your_hf_username
HF_MODEL_REPO=fraud-detection-models

# Kaggle (https://www.kaggle.com/settings -> Create New Token)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
